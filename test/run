#!/usr/bin/env bash
# DeepSeek Balance Tracker — test suite
# Run: ./test/run
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
BIN="$PROJECT_DIR/bin/deepseek-balance"

PASS=0
FAIL=0

TMPDIR=$(mktemp -d /tmp/deepseek-balance-test.XXXXXX)
export XDG_DATA_HOME="$TMPDIR"
DB_DIR="$XDG_DATA_HOME/deepseek-balance-tracker"
DB_FILE="$DB_DIR/balance.db"
mkdir -p "$DB_DIR"

cleanup() { rm -rf "$TMPDIR"; }
trap cleanup EXIT

# --- Helpers ---------------------------------------------------------------

setup_db() {
    # Start completely fresh each time — drop and recreate the DB.
    rm -f "$DB_FILE"
    sqlite3 "$DB_FILE" <<'SQL'
CREATE TABLE balance_snapshots (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    recorded_at INTEGER NOT NULL DEFAULT (unixepoch()),
    currency TEXT NOT NULL,
    total_balance_cents INTEGER NOT NULL,
    granted_balance_cents INTEGER NOT NULL,
    topped_up_balance_cents INTEGER NOT NULL
);
SQL
}

insert_row() {
    # Args: currency total_cents granted_cents topped_up_cents timestamp_text
    # timestamp_text is a human-readable datetime like "2026-06-19 10:00:00"
    sqlite3 "$DB_FILE" \
        "INSERT INTO balance_snapshots (currency, total_balance_cents, granted_balance_cents, topped_up_balance_cents, recorded_at)
         VALUES ('$1', $2, $3, $4, STRFTIME('%s', '$5'));"
}

assert_contains() {
    local label="$1" output="$2" pattern="$3"
    if echo "$output" | grep -qF "$pattern"; then
        echo "  PASS $label"
        PASS=$((PASS + 1))
    else
        echo "  FAIL $label"
        echo "    Expected to contain: $pattern"
        echo "    Actual: $output"
        FAIL=$((FAIL + 1))
    fi
}

assert_not_contains() {
    local label="$1" output="$2" pattern="$3"
    if ! echo "$output" | grep -qF "$pattern"; then
        echo "  PASS $label"
        PASS=$((PASS + 1))
    else
        echo "  FAIL $label"
        echo "    Expected NOT to contain: $pattern"
        echo "    Actual: $output"
        FAIL=$((FAIL + 1))
    fi
}

assert_json_key() {
    local label="$1" json="$2" jq_filter="$3" expected="$4"
    local actual
    actual=$(echo "$json" | jq -r "$jq_filter" 2>/dev/null || echo "JQ_ERROR")
    if [ "$actual" = "$expected" ]; then
        echo "  PASS $label"
        PASS=$((PASS + 1))
    else
        echo "  FAIL $label"
        echo "    JQ filter: $jq_filter"
        echo "    Expected:  $expected"
        echo "    Actual:    $actual"
        FAIL=$((FAIL + 1))
    fi
}

run_query() {
    # Run deepseek-balance with optional flags, capture stdout
    "$BIN" "$@"
}

today_at() { date +"%Y-%m-%d $1"; }

# --- Tests: empty DB -------------------------------------------------------

echo "=== Empty DB ==="
setup_db
OUT=$(run_query current 2>&1 || true)
# Empty DB with valid table — command succeeds with no output
assert_not_contains "empty DB no error" "$OUT" "ERROR"
# The 'no data yet' check only fires when DB file is missing
rm -f "$DB_FILE"
OUT=$(run_query current 2>&1 || true)
assert_contains "missing DB file error" "$OUT" "no data yet"

# --- Tests: single snapshot ------------------------------------------------

echo "=== Single snapshot ==="
setup_db
insert_row "USD" 426 0 426 "2026-06-19 10:00:00"

OUT=$(run_query current)
assert_contains "current shows balance" "$OUT" "\$4.26"
assert_contains "current shows currency" "$OUT" "USD"

OUT=$(run_query today)
assert_contains "today shows zero spend" "$OUT" "spent \$0.00"

OUT=$(run_query -j current)
assert_json_key "json current balance" "$OUT" '.[0].total_balance' "4.26"
assert_json_key "json current currency" "$OUT" '.[0].currency' 'USD'

# --- Tests: multiple snapshots with spend ----------------------------------

echo "=== Multiple snapshots ==="
setup_db
# Today: balance $5.00 → $4.50 (spent $0.50), then top-up to $6.00
insert_row "USD" 500 0 500 "$(today_at '08:00:00')"
insert_row "USD" 450 0 450 "$(today_at '08:05:00')"
insert_row "USD" 600 0 600 "$(today_at '08:10:00')"  # top-up
# $6.00 → $5.75 (spent $0.25)
insert_row "USD" 575 0 575 "$(today_at '08:15:00')"

OUT=$(run_query today)
assert_contains "today detects spend correctly" "$OUT" "spent \$0.75"
assert_contains "today shows snapshot count" "$OUT" "snapshots"

OUT=$(run_query -j today)
assert_json_key "json today spend" "$OUT" '.USD.spend_today' "0.75"
assert_json_key "json today count" "$OUT" '.USD.snapshots_today' "4"

# --- Tests: history --------------------------------------------------------

echo "=== History ==="
OUT=$(run_query history 2)
assert_contains "history shows latest first" "$OUT" "\$5.75"
assert_not_contains "history limits rows" "$OUT" "\$5.00"

OUT=$(run_query -j history 2)
assert_json_key "json history count" "$OUT" 'length' "2"

# --- Tests: currency filtering ---------------------------------------------

echo "=== Currency filtering ==="
setup_db
insert_row "USD" 100 0 100 "2026-06-19 10:00:00"
insert_row "CNY" 5000 0 5000 "2026-06-19 10:00:00"

OUT=$(run_query -c USD current)
assert_contains "filter USD only" "$OUT" "USD"
assert_not_contains "filter USD excludes CNY" "$OUT" "CNY"

OUT=$(run_query -c CNY current)
assert_contains "filter CNY only" "$OUT" "CNY"
assert_not_contains "filter CNY excludes USD" "$OUT" "USD"

OUT=$(run_query -c both current)
assert_contains "both includes USD" "$OUT" "USD"
assert_contains "both includes CNY" "$OUT" "CNY"

# --- Tests: multi-day summary ----------------------------------------------

echo "=== Summary ==="
setup_db
# Insert data across 5 days with known spend pattern
# Day -4: $10.00 → $9.00 (spent $1.00)
insert_row "USD" 1000 0 1000 "$(date -d '4 days ago' +'%Y-%m-%d 10:00:00')"
insert_row "USD" 950 0 950   "$(date -d '4 days ago' +'%Y-%m-%d 10:05:00')"
insert_row "USD" 900 0 900   "$(date -d '4 days ago' +'%Y-%m-%d 10:10:00')"
# Day -3: $9.00 → $8.00 (spent $1.00)
insert_row "USD" 900 0 900   "$(date -d '3 days ago' +'%Y-%m-%d 10:00:00')"
insert_row "USD" 800 0 800   "$(date -d '3 days ago' +'%Y-%m-%d 10:05:00')"
# Day -2: $8.00 → $7.50 (spent $0.50)
insert_row "USD" 800 0 800   "$(date -d '2 days ago' +'%Y-%m-%d 10:00:00')"
insert_row "USD" 750 0 750   "$(date -d '2 days ago' +'%Y-%m-%d 10:05:00')"
# Day -1: $7.50 → $7.00 (spent $0.50)
insert_row "USD" 750 0 750   "$(date -d '1 day ago' +'%Y-%m-%d 10:00:00')"
insert_row "USD" 700 0 700   "$(date -d '1 day ago' +'%Y-%m-%d 10:05:00')"
# Today: $7.00 → $6.50 (spent $0.50, still in progress)
insert_row "USD" 700 0 700   "$(date +'%Y-%m-%d 10:00:00')"
insert_row "USD" 650 0 650   "$(date +'%Y-%m-%d 10:05:00')"

OUT=$(run_query summary)
assert_contains "summary shows current balance" "$OUT" "balance \$6.50"
assert_contains "summary shows days tracked" "$OUT" "5 days tracked"

OUT=$(run_query -j summary)
assert_json_key "json summary balance" "$OUT" '.USD.current_balance' "6.50"
assert_json_key "json summary days" "$OUT" '.USD.days_tracked' "5"

# --- Tests: top-up not counted as negative spend ---------------------------

echo "=== Top-up handling ==="
setup_db
insert_row "USD" 500 0 500 "$(today_at '10:00:00')"
insert_row "USD" 400 0 400 "$(today_at '10:05:00')"  # spent $1.00
insert_row "USD" 900 0 900 "$(today_at '10:10:00')"  # topped up $5.00 — should NOT be counted

OUT=$(run_query today)
assert_contains "top-up ignored in spend" "$OUT" "spent \$1.00"
assert_not_contains "top-up not negative" "$OUT" "spent -"

# --- Tests: JSON output flag -----------------------------------------------

echo "=== JSON output ==="
setup_db
insert_row "USD" 426 0 426 "2026-06-19 10:00:00"

OUT=$(run_query -j current)
assert_contains "json is valid JSON array start" "$OUT" "["
assert_contains "json contains currency" "$OUT" '"currency":"USD"'

OUT=$(run_query current)
assert_contains "text is not JSON" "$OUT" "\$4.26"
assert_not_contains "text has no brackets" "$OUT" "["

# --- Tests: recent (last hour) -----------------------------------------------

echo "=== Recent ==="
setup_db
# Simulate snapshots over the last 2 hours (use relative timestamps in SQL)
sqlite3 "$DB_FILE" <<'SQL'
INSERT INTO balance_snapshots (currency, total_balance_cents, granted_balance_cents, topped_up_balance_cents, recorded_at)
VALUES
  ('USD', 500, 0, 500, unixepoch('now', '-65 minutes')),
  ('USD', 450, 0, 450, unixepoch('now', '-55 minutes')),
  ('USD', 430, 0, 430, unixepoch('now', '-45 minutes')),
  ('USD', 420, 0, 420, unixepoch('now', '-35 minutes'));
SQL

OUT=$(run_query recent)
# 3 rows inside 60-min window (-55, -45, -35). Deltas: 500→450=50¢ + 450→430=20¢ + 430→420=10¢ = 80¢
assert_contains "recent detects spend in last hour" "$OUT" "spent \$0.80"
assert_contains "recent shows snapshot count" "$OUT" "3 snapshots"

OUT=$(run_query -j recent)
assert_json_key "json recent spend" "$OUT" '.USD.spend_last_hour' "0.80"

# --- Tests: edge cases -----------------------------------------------------

echo "=== Edge cases ==="

# Invalid subcommand
OUT=$(run_query invalid 2>&1 || true)
assert_contains "invalid subcommand error" "$OUT" "unknown subcommand"

# Help flag
OUT=$(run_query -h 2>&1 || true)
assert_contains "help shows usage" "$OUT" "Usage:"

# Custom history count
setup_db
for i in $(seq 1 5); do
    insert_row "USD" "$((100 + i))" 0 "$((100 + i))" "2026-06-19 10:0${i}:00"
done
OUT=$(run_query history 3)
# Should show exactly 3 rows plus header = 4 lines
LINES=$(echo "$OUT" | wc -l)
assert_contains "history -N shows N+header lines" "$LINES" "4"

# Summary with only 1 snapshot (no deltas, averages should be 0)
setup_db
insert_row "USD" 500 0 500 "$(date +'%Y-%m-%d 10:00:00')"
OUT=$(run_query summary)
assert_contains "single snapshot summary shows balance" "$OUT" "balance \$5.00"
assert_contains "single snapshot has 0 avg" "$OUT" "\$0.00/day"

# --- Tests: check-alert ----------------------------------------------------

echo "=== Check-alert ==="

# No thresholds → disabled
setup_db
insert_row "USD" 426 0 426 "2026-06-19 10:00:00"
OUT=$(ALERT_THRESHOLD_USD="" ALERT_THRESHOLD_CNY="" run_query check-alert 2>&1)
assert_contains "no thresholds: USD disabled" "$OUT" "USD  disabled"
assert_contains "no thresholds: CNY disabled" "$OUT" "CNY  disabled"
assert_not_contains "no thresholds: no ALERT" "$OUT" "ALERT"

# Above threshold → ok
setup_db
insert_row "USD" 403 0 403 "2026-06-19 10:00:00"
OUT=$(ALERT_THRESHOLD_USD="1.00" ALERT_THRESHOLD_CNY="" run_query check-alert 2>&1)
assert_contains "above threshold shows ok" "$OUT" "ok"
assert_contains "above threshold shows balance" "$OUT" "\$4.03"

# Below threshold → ALERT, exit 1
setup_db
insert_row "USD" 50 0 50 "2026-06-19 10:00:00"
OUT=$(ALERT_THRESHOLD_USD="1.00" ALERT_THRESHOLD_CNY="" run_query check-alert 2>&1 || true)
assert_contains "below threshold shows ALERT" "$OUT" "ALERT"

# Verify exit code is 1 when alert fires
setup_db
insert_row "USD" 50 0 50 "2026-06-19 10:00:00"
ACTUAL_EXIT=$(ALERT_THRESHOLD_USD="2.00" ALERT_THRESHOLD_CNY="" run_query check-alert >/dev/null 2>&1; echo $?)
if [ "$ACTUAL_EXIT" = "1" ]; then
    echo "  PASS check-alert exit code 1 on alert"
    PASS=$((PASS + 1))
else
    echo "  FAIL check-alert exit code — expected 1, got $ACTUAL_EXIT"
    FAIL=$((FAIL + 1))
fi

# JSON output — above threshold
setup_db
insert_row "USD" 403 0 403 "2026-06-19 10:00:00"
OUT=$(ALERT_THRESHOLD_USD="1.00" ALERT_THRESHOLD_CNY="" run_query -j check-alert 2>&1)
assert_json_key "json alert false when above" "$OUT" '.USD.alert' "false"
assert_json_key "json balance is correct" "$OUT" '.USD.balance' "4.03"
assert_json_key "json threshold is correct" "$OUT" '.USD.threshold' "1.00"

# JSON output — below threshold
setup_db
insert_row "USD" 50 0 50 "2026-06-19 10:00:00"
OUT=$(ALERT_THRESHOLD_USD="2.00" ALERT_THRESHOLD_CNY="" run_query -j check-alert 2>&1 || true)
assert_json_key "json alert true when below" "$OUT" '.USD.alert' "true"
assert_json_key "json balance cents" "$OUT" '.USD.balance' "0.50"

# CNY threshold
setup_db
insert_row "CNY" 500 0 500 "2026-06-19 10:00:00"
OUT=$(ALERT_THRESHOLD_CNY="10.00" run_query check-alert 2>&1 || true)
assert_contains "cny below threshold ALERT" "$OUT" "ALERT"

setup_db
insert_row "CNY" 5000 0 5000 "2026-06-19 10:00:00"
OUT=$(ALERT_THRESHOLD_CNY="10.00" run_query check-alert 2>&1)
assert_contains "cny above threshold ok" "$OUT" "ok"

# Both currencies at once
setup_db
insert_row "USD" 403 0 403 "2026-06-19 10:00:00"
insert_row "CNY" 500 0 500 "2026-06-19 10:01:00"
OUT=$(ALERT_THRESHOLD_USD="1.00" ALERT_THRESHOLD_CNY="10.00" run_query check-alert 2>&1 || true)
assert_contains "both: USD ok" "$OUT" "USD  \$4.03"
assert_contains "both: CNY ALERT" "$OUT" "ALERT"

# No data → no data message
setup_db
OUT=$(ALERT_THRESHOLD_USD="1.00" ALERT_THRESHOLD_CNY="" run_query check-alert 2>&1 || true)
assert_contains "no data shows message" "$OUT" "no data"

# --- Tests: poll alert integration -----------------------------------------

echo "=== Poll alert integration ==="

# Set up alert command that writes to a marker file when called
ALERT_MARKER="$TMPDIR/alert-fired"
cat > "$TMPDIR/alert-script" <<SCRIPTEOF
#!/usr/bin/env bash
echo "fired currency=\$DBT_CURRENCY balance=\$DBT_BALANCE threshold=\$DBT_THRESHOLD" > "$ALERT_MARKER"
SCRIPTEOF
chmod +x "$TMPDIR/alert-script"

# Mock curl that returns a below-threshold balance
MOCK_CURL="$TMPDIR/curl"
cat > "$MOCK_CURL" <<'CURLEOF'
#!/usr/bin/env bash
# Return a low balance that should trigger the alert.
# Must mimic curl -w '\n%{http_code}' output: body + newline + http_code
echo '{"balance_infos":[{"currency":"USD","total_balance":"0.95","granted_balance":"0.00","topped_up_balance":"0.95"}]}'
echo "200"
CURLEOF
chmod +x "$MOCK_CURL"

# Config dir with secrets
mkdir -p "$TMPDIR/config/deepseek-balance"
cat > "$TMPDIR/config/deepseek-balance/secrets.env" <<EOF
DEEPSEEK_API_KEY=sk-test
CURRENCY=both
RETENTION_DAYS=0
ALERT_THRESHOLD_USD=1.00
ALERT_COMMAND=$TMPDIR/alert-script
EOF

# State dir
mkdir -p "$TMPDIR/state/deepseek-balance-tracker"

# Pre-populate DB above threshold (state should be ok)
setup_db
insert_row "USD" 200 0 200 "2026-06-19 10:00:00"

# Write initial state as "ok" so alert can fire
mkdir -p "$TMPDIR/state"
echo "USD:ok" > "$TMPDIR/state/deepseek-balance-tracker/alert-state"

# Run the poll with mock curl and our config
rm -f "$ALERT_MARKER"
PATH="$TMPDIR:$PATH" \
  XDG_DATA_HOME="$XDG_DATA_HOME" \
  XDG_CONFIG_HOME="$TMPDIR/config" \
  XDG_STATE_HOME="$TMPDIR/state" \
  bash "$PROJECT_DIR/bin/deepseek-balance-poll" >/dev/null 2>&1 || true

if [ -f "$ALERT_MARKER" ]; then
    echo "  PASS poll alert fires when balance drops below threshold"
    PASS=$((PASS + 1))
    # Verify env vars were passed
    MARKER_CONTENT=$(cat "$ALERT_MARKER")
    assert_contains "poll alert has currency" "$MARKER_CONTENT" "currency=USD"
    assert_contains "poll alert has balance" "$MARKER_CONTENT" "balance=0.95"
    assert_contains "poll alert has threshold" "$MARKER_CONTENT" "threshold=1.00"
else
    echo "  FAIL poll alert did not fire (marker file not found)"
    FAIL=$((FAIL + 1))
fi

# Test: alert does NOT re-fire when already in "fired" state
rm -f "$ALERT_MARKER"
echo "USD:fired" > "$TMPDIR/state/deepseek-balance-tracker/alert-state"

PATH="$TMPDIR:$PATH" \
  XDG_DATA_HOME="$XDG_DATA_HOME" \
  XDG_CONFIG_HOME="$TMPDIR/config" \
  XDG_STATE_HOME="$TMPDIR/state" \
  bash "$PROJECT_DIR/bin/deepseek-balance-poll" >/dev/null 2>&1 || true

if [ -f "$ALERT_MARKER" ]; then
    echo "  FAIL poll alert re-fired when already in fired state"
    FAIL=$((FAIL + 1))
else
    echo "  PASS poll alert does not re-fire in fired state"
    PASS=$((PASS + 1))
fi

# Test: auto re-arm when balance goes back above threshold
rm -f "$ALERT_MARKER"

# Mock curl that returns above-threshold balance
cat > "$MOCK_CURL" <<'CURLEOF'
#!/usr/bin/env bash
echo '{"balance_infos":[{"currency":"USD","total_balance":"5.00","granted_balance":"0.00","topped_up_balance":"5.00"}]}'
echo "200"
CURLEOF

echo "USD:fired" > "$TMPDIR/state/deepseek-balance-tracker/alert-state"

PATH="$TMPDIR:$PATH" \
  XDG_DATA_HOME="$XDG_DATA_HOME" \
  XDG_CONFIG_HOME="$TMPDIR/config" \
  XDG_STATE_HOME="$TMPDIR/state" \
  bash "$PROJECT_DIR/bin/deepseek-balance-poll" >/dev/null 2>&1 || true

STATE_AFTER=$(cat "$TMPDIR/state/deepseek-balance-tracker/alert-state")
if echo "$STATE_AFTER" | grep -q "USD:ok"; then
    echo "  PASS poll alert re-arms when balance returns above threshold"
    PASS=$((PASS + 1))
else
    echo "  FAIL poll alert did not re-arm (state: $STATE_AFTER)"
    FAIL=$((FAIL + 1))
fi

# --- Tests: RETENTION_DAYS pruning -----------------------------------------

echo "=== Retention pruning ==="

# Set up mock curl that returns a simple balance
cat > "$MOCK_CURL" <<'CURLEOF'
#!/usr/bin/env bash
echo '{"balance_infos":[{"currency":"USD","total_balance":"10.00","granted_balance":"0.00","topped_up_balance":"10.00"}]}'
echo "200"
CURLEOF

# Secrets file with retention enabled
cat > "$TMPDIR/config/deepseek-balance/secrets.env" <<EOF
DEEPSEEK_API_KEY=sk-test
CURRENCY=both
RETENTION_DAYS=90
EOF

# DB with old data (100 days ago) and recent data (today)
setup_db
sqlite3 "$DB_FILE" <<SQL
INSERT INTO balance_snapshots (currency, total_balance_cents, granted_balance_cents, topped_up_balance_cents, recorded_at)
VALUES
  ('USD', 1000, 0, 1000, unixepoch('now', '-100 days')),
  ('USD', 900, 0, 900,  unixepoch('now', '-100 days')),
  ('USD', 1100, 0, 1100, unixepoch('now', '-1 day')),
  ('USD', 1050, 0, 1050, unixepoch('now', '-1 day'));
SQL

OLD_COUNT_BEFORE=$(sqlite3 "$DB_FILE" "SELECT COUNT(*) FROM balance_snapshots WHERE recorded_at < unixepoch('now', '-90 days');")
RECENT_COUNT_BEFORE=$(sqlite3 "$DB_FILE" "SELECT COUNT(*) FROM balance_snapshots WHERE recorded_at >= unixepoch('now', '-90 days');")

# Run the poll with retention
PATH="$TMPDIR:$PATH" \
  XDG_DATA_HOME="$XDG_DATA_HOME" \
  XDG_CONFIG_HOME="$TMPDIR/config" \
  XDG_STATE_HOME="$TMPDIR/state" \
  RETENTION_DAYS=90 \
  bash "$PROJECT_DIR/bin/deepseek-balance-poll" >/dev/null 2>&1 || true

OLD_COUNT_AFTER=$(sqlite3 "$DB_FILE" "SELECT COUNT(*) FROM balance_snapshots WHERE recorded_at < unixepoch('now', '-90 days');")
RECENT_COUNT_AFTER=$(sqlite3 "$DB_FILE" "SELECT COUNT(*) FROM balance_snapshots WHERE recorded_at >= unixepoch('now', '-90 days');")

if [ "$OLD_COUNT_BEFORE" -gt 0 ] && [ "$OLD_COUNT_AFTER" -eq 0 ]; then
    echo "  PASS retention deletes old rows (was $OLD_COUNT_BEFORE, now $OLD_COUNT_AFTER)"
    PASS=$((PASS + 1))
else
    echo "  FAIL retention did not delete old rows (before=$OLD_COUNT_BEFORE, after=$OLD_COUNT_AFTER)"
    FAIL=$((FAIL + 1))
fi

if [ "$RECENT_COUNT_AFTER" -gt 0 ]; then
    echo "  PASS retention keeps recent rows ($RECENT_COUNT_AFTER surviving)"
    PASS=$((PASS + 1))
else
    echo "  FAIL retention deleted recent rows too"
    FAIL=$((FAIL + 1))
fi

# --- Results ---------------------------------------------------------------

echo ""
echo "============================"
echo "Results: $PASS passed, $FAIL failed"
echo "============================"

if [ "$FAIL" -gt 0 ]; then
    exit 1
fi
