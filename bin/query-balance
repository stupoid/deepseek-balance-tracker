#!/usr/bin/env bash
set -euo pipefail

DB_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/deepseek-balance-tracker/balance.db"

usage() {
    cat <<'EOF'
Usage: query-balance [OPTIONS] <subcommand> [args]

Subcommands:
  current        Latest balance per currency
  today          Total spend today (UTC)
  history [N]    Last N snapshots (default 24)
  summary        Weekly/monthly stats + projection

Options:
  -c USD|CNY     Override currency (default: from $CURRENCY env, or 'both')
  -h             Show this help

Output: JSON
EOF
    exit 0
}

# --- Parse options ---------------------------------------------------------
CURRENCY="${CURRENCY:-both}"
while getopts "c:h" opt; do
    case "$opt" in
        c) CURRENCY="$OPTARG" ;;
        h) usage ;;
        *) usage ;;
    esac
done
shift $((OPTIND - 1))

SUBCMD="${1:-}"
N="${2:-24}"

if [ -z "$SUBCMD" ]; then
    usage
fi

if [ ! -f "$DB_FILE" ]; then
    echo '{"error":"No data yet. Run poll-balance first."}'
    exit 1
fi

# --- Helpers ---------------------------------------------------------------
get_currencies() {
    if [ "$CURRENCY" = "both" ]; then
        sqlite3 "$DB_FILE" "SELECT DISTINCT currency FROM balance_snapshots ORDER BY currency;"
    else
        echo "$CURRENCY"
    fi
}

# --- JSON formatting helpers ------------------------------------------------
# sqlite3 -json produces floating-point noise for REAL values.
# We format manually to get clean 2-decimal output from integer cents.

cents_to_dollars() {
    awk -v c="$1" 'BEGIN { printf "%.2f", c / 100.0 }'
}

# Output a single balance row as a JSON object
json_balance_row() {
    local currency="$1" total_cents="$2" granted_cents="$3" topped_cents="$4" recorded_at="$5"
    local total granted topped
    total=$(cents_to_dollars "$total_cents")
    granted=$(cents_to_dollars "$granted_cents")
    topped=$(cents_to_dollars "$topped_cents")
    printf '{"currency":"%s","total_balance":%s,"granted_balance":%s,"topped_up_balance":%s,"recorded_at":"%s"}' \
        "$currency" "$total" "$granted" "$topped" "$recorded_at"
}

# --- Subcommands -----------------------------------------------------------

cmd_current() {
    local where_clause
    if [ "$CURRENCY" = "both" ]; then
        where_clause="WHERE id IN (SELECT MAX(id) FROM balance_snapshots GROUP BY currency)"
    else
        where_clause="WHERE currency = '$CURRENCY'"
    fi

    local first=1
    echo "["
    while IFS='|' read -r currency total_cents granted_cents topped_cents recorded_at; do
        [ "$first" = 1 ] || echo ","
        first=0
        json_balance_row "$currency" "$total_cents" "$granted_cents" "$topped_cents" "$recorded_at"
    done < <(sqlite3 -separator '|' "$DB_FILE" \
        "SELECT currency, total_balance_cents, granted_balance_cents, topped_up_balance_cents, recorded_at
         FROM balance_snapshots $where_clause ORDER BY currency;")
    echo ""
    echo "]"
}

cmd_today() {
    echo "{"
    local first=1
    for CUR in $(get_currencies); do
        [ "$first" = 1 ] || echo ","
        first=0

        # Sum of positive deltas (prev - curr) across today's snapshots, in cents.
        SPEND_CENTS=$(sqlite3 "$DB_FILE" "
            WITH ordered AS (
                SELECT topped_up_balance_cents,
                       LAG(topped_up_balance_cents) OVER (ORDER BY id) AS prev
                FROM balance_snapshots
                WHERE currency = '$CUR'
                  AND date(recorded_at) = date('now')
            )
            SELECT COALESCE(SUM(MAX(prev - topped_up_balance_cents, 0)), 0)
            FROM ordered
            WHERE prev IS NOT NULL;
        ")

        ROW_COUNT=$(sqlite3 "$DB_FILE" \
            "SELECT COUNT(*) FROM balance_snapshots
             WHERE currency = '$CUR' AND date(recorded_at) = date('now');")

        SPEND=$(awk -v c="$SPEND_CENTS" 'BEGIN { printf "%.2f", c / 100.0 }')
        printf '  "%s": {"spend_today": %s, "snapshots_today": %s}' \
            "$CUR" "$SPEND" "$ROW_COUNT"
    done
    echo ""
    echo "}"
}

cmd_history() {
    local where_clause
    if [ "$CURRENCY" = "both" ]; then
        where_clause=""
    else
        where_clause="WHERE currency = '$CURRENCY'"
    fi

    local first=1
    echo "["
    while IFS='|' read -r currency total_cents granted_cents topped_cents recorded_at; do
        [ "$first" = 1 ] || echo ","
        first=0
        json_balance_row "$currency" "$total_cents" "$granted_cents" "$topped_cents" "$recorded_at"
    done < <(sqlite3 -separator '|' "$DB_FILE" \
        "SELECT currency, total_balance_cents, granted_balance_cents, topped_up_balance_cents, recorded_at
         FROM balance_snapshots $where_clause ORDER BY id DESC LIMIT $N;")
    echo ""
    echo "]"
}

cmd_summary() {
    echo "{"
    local first=1
    for CUR in $(get_currencies); do
        [ "$first" = 1 ] || echo ","
        first=0

        # Current topped-up balance (in cents)
        CURRENT_CENTS=$(sqlite3 "$DB_FILE" \
            "SELECT topped_up_balance_cents FROM balance_snapshots
             WHERE currency = '$CUR'
             ORDER BY id DESC LIMIT 1;")

        CURRENT=$(awk -v c="$CURRENT_CENTS" 'BEGIN { printf "%.2f", c / 100.0 }')

        # Days tracked
        DAYS_TRACKED=$(sqlite3 "$DB_FILE" \
            "SELECT COUNT(DISTINCT date(recorded_at))
             FROM balance_snapshots WHERE currency = '$CUR';")

        # avg_daily helper: returns average daily spend in cents, then convert
        avg_daily_spend_cents() {
            local DAYS="$1"
            sqlite3 "$DB_FILE" "
                WITH consecutive AS (
                    SELECT date(recorded_at) AS day,
                           topped_up_balance_cents,
                           LAG(topped_up_balance_cents) OVER (ORDER BY id) AS prev
                    FROM balance_snapshots
                    WHERE currency = '$CUR'
                      AND date(recorded_at) >= date('now', '-${DAYS} days')
                      AND date(recorded_at) < date('now')
                ),
                daily_spend AS (
                    SELECT day, SUM(MAX(prev - topped_up_balance_cents, 0)) AS spend
                    FROM consecutive
                    WHERE prev IS NOT NULL
                    GROUP BY day
                )
                SELECT COALESCE(ROUND(AVG(spend)), 0)
                FROM daily_spend
                WHERE spend > 0;
            "
        }

        AVG_7D_CENTS=$(avg_daily_spend_cents 7)
        AVG_30D_CENTS=$(avg_daily_spend_cents 30)

        AVG_7D=$(awk -v c="$AVG_7D_CENTS" 'BEGIN { printf "%.2f", c / 100.0 }')
        AVG_30D=$(awk -v c="$AVG_30D_CENTS" 'BEGIN { printf "%.2f", c / 100.0 }')

        # Estimated days remaining (based on 30d avg in cents)
        EST_DAYS="null"
        if [ "$AVG_30D_CENTS" != "0" ]; then
            EST_DAYS=$(awk -v bal="$CURRENT_CENTS" -v avg="$AVG_30D_CENTS" \
                'BEGIN { printf "%d", bal / avg }' 2>/dev/null || echo "null")
            if [ -z "$EST_DAYS" ]; then
                EST_DAYS="null"
            fi
        fi

        printf '  "%s": {' "$CUR"
        printf '"current_balance": %s, ' "$CURRENT"
        printf '"avg_daily_spend_7d": %s, ' "$AVG_7D"
        printf '"avg_daily_spend_30d": %s, ' "$AVG_30D"
        printf '"days_tracked": %s, ' "$DAYS_TRACKED"
        printf '"estimated_days_left": %s' "$EST_DAYS"
        echo -n "}"
    done
    echo ""
    echo "}"
}

# --- Dispatch --------------------------------------------------------------
case "$SUBCMD" in
    current) cmd_current ;;
    today)   cmd_today ;;
    history) cmd_history ;;
    summary) cmd_summary ;;
    *)       echo "{\"error\":\"Unknown subcommand: $SUBCMD\"}" >&2; exit 2 ;;
esac
