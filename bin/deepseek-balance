#!/usr/bin/env bash
set -euo pipefail

DB_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/deepseek-balance-tracker/balance.db"
OUTPUT_MODE="text"

usage() {
    cat <<'EOF'
deepseek-balance — query DeepSeek account balance and usage from local history.

Usage:
  deepseek-balance [-j] [-c USD|CNY] <subcommand> [args]

Subcommands:
  current         Latest balance per currency (total, granted, topped-up)
  today           Total spend today in UTC (sum of balance decreases)
  recent          Total spend in the last 60 minutes
  history [N]     Last N balance snapshots (default: 24)
  summary         Averages over 7d/30d, estimated days remaining, days tracked
  check-alert     Check current balance against configured alert thresholds

Options:
  -j              Output JSON instead of text (use this for scripting/bots)
  -c USD|CNY      Filter to a single currency (default: all, or $CURRENCY env)
  -h              Show this help

Exit codes:
  0   Success
  1   No database found, or alert threshold breached (check-alert)
  2   Invalid subcommand or argument

Examples for bots/scripts (always use -j):
  deepseek-balance -j current | jq '.[0].topped_up_balance'
  deepseek-balance -j -c USD today | jq '.USD.spend_today'
  deepseek-balance -j -c USD recent | jq '.USD.spend_last_hour'
  deepseek-balance -j summary | jq '.USD.estimated_days_left'
  deepseek-balance -j history 5

Human-readable examples:
  deepseek-balance current
  deepseek-balance -c USD today
  deepseek-balance recent
  deepseek-balance history 10
  deepseek-balance summary
  deepseek-balance -j check-alert

Data source:
  ~/.local/share/deepseek-balance-tracker/balance.db
  Populated by: deepseek-balance-poll (systemd timer, every 5 min)
EOF
    exit 0
}

# --- Parse options ---------------------------------------------------------
CURRENCY="${CURRENCY:-both}"
while getopts "c:jh" opt; do
    case "$opt" in
        c) CURRENCY="$OPTARG" ;;
        j) OUTPUT_MODE="json" ;;
        h) usage ;;
        *) usage ;;
    esac
done
shift $((OPTIND - 1))

SUBCMD="${1:-}"
N="${2:-24}"

# Validate inputs
if [[ ! "$CURRENCY" =~ ^(USD|CNY|both)$ ]]; then
    echo "deepseek-balance: invalid currency '$CURRENCY' — must be USD, CNY, or both" >&2
    exit 2
fi
if [[ ! "$N" =~ ^[0-9]+$ ]]; then
    echo "deepseek-balance: invalid count '$N' — must be a positive integer" >&2
    exit 2
fi

if [ -z "$SUBCMD" ]; then usage; fi
if [ ! -f "$DB_FILE" ]; then
    echo "deepseek-balance: no data yet — run deepseek-balance-poll first" >&2
    exit 1
fi

# --- Helpers ---------------------------------------------------------------
get_currencies() {
    if [ "$CURRENCY" = "both" ]; then
        sqlite3 "$DB_FILE" "SELECT DISTINCT currency FROM balance_snapshots ORDER BY currency;"
    else
        echo "$CURRENCY"
    fi
}

cents_to_dollars() {
    awk -v c="$1" 'BEGIN { printf "%.2f", c / 100.0 }'
}

# Compute spend in cents for a given currency over a time window.
# Usage: avg_spend_cents <currency> <minutes>
# Returns total spend (positive deltas only) in cents.
spend_in_window_cents() {
    local cur="$1" minutes="$2"
    sqlite3 "$DB_FILE" "
        WITH ordered AS (
            SELECT topped_up_balance_cents,
                   LAG(topped_up_balance_cents) OVER (ORDER BY id) AS prev
            FROM balance_snapshots
            WHERE currency = '$cur'
              AND recorded_at >= unixepoch('now', '-${minutes} minutes')
        )
        SELECT COALESCE(SUM(MAX(prev - topped_up_balance_cents, 0)), 0)
        FROM ordered WHERE prev IS NOT NULL;"
}

# Average daily spend (in cents) over N days for a currency.
avg_daily_spend_cents() {
    local cur="$1" days="$2"
    sqlite3 "$DB_FILE" "
        WITH consecutive AS (
            SELECT date(recorded_at, 'unixepoch') AS day,
                   topped_up_balance_cents,
                   LAG(topped_up_balance_cents) OVER (ORDER BY id) AS prev
            FROM balance_snapshots
            WHERE currency = '$cur'
              AND date(recorded_at, 'unixepoch') >= date('now', '-${days} days')
              AND date(recorded_at, 'unixepoch') < date('now')
        ),
        daily_spend AS (
            SELECT day, SUM(MAX(prev - topped_up_balance_cents, 0)) AS spend
            FROM consecutive WHERE prev IS NOT NULL GROUP BY day
        )
        SELECT COALESCE(ROUND(AVG(spend)), 0)
        FROM daily_spend WHERE spend > 0;"
}

# --- JSON output functions (reuse existing JSON logic) ---------------------
json_balance_row() {
    local c="$1" tc="$2" gc="$3" pc="$4" ts="$5"
    printf '{"currency":"%s","total_balance":%s,"granted_balance":%s,"topped_up_balance":%s,"recorded_at":"%s"}' \
        "$c" "$(cents_to_dollars "$tc")" "$(cents_to_dollars "$gc")" "$(cents_to_dollars "$pc")" "$ts"
}

json_current() {
    local where="WHERE id IN (SELECT MAX(id) FROM balance_snapshots GROUP BY currency)"
    [ "$CURRENCY" != "both" ] && where="WHERE currency = '$CURRENCY'"
    echo "["
    local first=1
    while IFS='|' read -r c tc gc pc ts; do
        [ "$first" = 1 ] || echo ","
        first=0
        json_balance_row "$c" "$tc" "$gc" "$pc" "$ts"
    done < <(sqlite3 -separator '|' "$DB_FILE" \
        "SELECT currency,total_balance_cents,granted_balance_cents,topped_up_balance_cents,datetime(recorded_at, 'unixepoch') AS recorded_at
         FROM balance_snapshots $where ORDER BY currency;")
    echo ""
    echo "]"
}

json_today() {
    echo "{"
    local first=1
    for CUR in $(get_currencies); do
        [ "$first" = 1 ] || echo ","
        first=0
        local sc rc
        sc=$(sqlite3 "$DB_FILE" "
            WITH ordered AS (
                SELECT topped_up_balance_cents,
                       LAG(topped_up_balance_cents) OVER (ORDER BY id) AS prev
                FROM balance_snapshots
                WHERE currency = '$CUR' AND date(recorded_at, 'unixepoch') = date('now')
            )
            SELECT COALESCE(SUM(MAX(prev - topped_up_balance_cents, 0)), 0)
            FROM ordered WHERE prev IS NOT NULL;")
        rc=$(sqlite3 "$DB_FILE" \
            "SELECT COUNT(*) FROM balance_snapshots
             WHERE currency = '$CUR' AND date(recorded_at, 'unixepoch') = date('now');")
        printf '  "%s": {"spend_today": %s, "snapshots_today": %s}' \
            "$CUR" "$(cents_to_dollars "$sc")" "$rc"
    done
    echo ""
    echo "}"
}

json_history() {
    local where=""
    [ "$CURRENCY" != "both" ] && where="WHERE currency = '$CURRENCY'"
    echo "["
    local first=1
    while IFS='|' read -r c tc gc pc ts; do
        [ "$first" = 1 ] || echo ","
        first=0
        json_balance_row "$c" "$tc" "$gc" "$pc" "$ts"
    done < <(sqlite3 -separator '|' "$DB_FILE" \
        "SELECT currency,total_balance_cents,granted_balance_cents,topped_up_balance_cents,datetime(recorded_at, 'unixepoch') AS recorded_at
         FROM balance_snapshots $where ORDER BY id DESC LIMIT $N;")
    echo ""
    echo "]"
}

json_summary() {
    echo "{"
    local first=1
    for CUR in $(get_currencies); do
        [ "$first" = 1 ] || echo ","
        first=0
        local cc dt a7 a30
        cc=$(sqlite3 "$DB_FILE" \
            "SELECT topped_up_balance_cents FROM balance_snapshots
             WHERE currency = '$CUR' ORDER BY id DESC LIMIT 1;")
        dt=$(sqlite3 "$DB_FILE" \
            "SELECT COUNT(DISTINCT date(recorded_at, 'unixepoch'))
             FROM balance_snapshots WHERE currency = '$CUR';")
        a7=$(avg_daily_spend_cents "$CUR" 7)
        a30=$(avg_daily_spend_cents "$CUR" 30)
        local ed="null"
        [ "$a30" != "0" ] && ed=$(awk -v b="$cc" -v a="$a30" 'BEGIN { printf "%d", b / a }')
        printf '  "%s": {' "$CUR"
        printf '"current_balance": %s, ' "$(cents_to_dollars "$cc")"
        printf '"avg_daily_spend_7d": %s, ' "$(cents_to_dollars "$a7")"
        printf '"avg_daily_spend_30d": %s, ' "$(cents_to_dollars "$a30")"
        printf '"days_tracked": %s, ' "$dt"
        printf '"estimated_days_left": %s' "$ed"
        echo -n "}"
    done
    echo ""
    echo "}"
}

# --- JSON: recent ----------------------------------------------------------
json_recent() {
    echo "{"
    local first=1
    for CUR in $(get_currencies); do
        [ "$first" = 1 ] || echo ","
        first=0
        local sc rc
        sc=$(spend_in_window_cents "$CUR" 60)
        rc=$(sqlite3 "$DB_FILE" \
            "SELECT COUNT(*) FROM balance_snapshots
             WHERE currency = '$CUR'
               AND recorded_at >= unixepoch('now', '-60 minutes');")
        printf '  "%s": {"spend_last_hour": %s, "snapshots": %s}' \
            "$CUR" "$(cents_to_dollars "$sc")" "$rc"
    done
    echo ""
    echo "}"
}

# --- Text: recent ----------------------------------------------------------
text_recent() {
    for CUR in $(get_currencies); do
        local sc rc
        sc=$(spend_in_window_cents "$CUR" 60)
        rc=$(sqlite3 "$DB_FILE" \
            "SELECT COUNT(*) FROM balance_snapshots
             WHERE currency = '$CUR'
               AND recorded_at >= unixepoch('now', '-60 minutes');")
        printf "%-4s spent \$%s in the last hour  (%s snapshots)\n" \
            "$CUR" "$(cents_to_dollars "$sc")" "$rc"
    done
}

# --- Text output functions -------------------------------------------------

text_current() {
    local where="WHERE id IN (SELECT MAX(id) FROM balance_snapshots GROUP BY currency)"
    [ "$CURRENCY" != "both" ] && where="WHERE currency = '$CURRENCY'"
    while IFS='|' read -r c tc gc pc ts; do
        printf "%-4s \$%-8s total  \$%-8s granted  \$%-8s topped-up  (%s)\n" \
            "$c" "$(cents_to_dollars "$tc")" "$(cents_to_dollars "$gc")" "$(cents_to_dollars "$pc")" "$ts"
    done < <(sqlite3 -separator '|' "$DB_FILE" \
        "SELECT currency,total_balance_cents,granted_balance_cents,topped_up_balance_cents,datetime(recorded_at, 'unixepoch') AS recorded_at
         FROM balance_snapshots $where ORDER BY currency;")
}

text_today() {
    for CUR in $(get_currencies); do
        local sc rc
        sc=$(sqlite3 "$DB_FILE" "
            WITH ordered AS (
                SELECT topped_up_balance_cents,
                       LAG(topped_up_balance_cents) OVER (ORDER BY id) AS prev
                FROM balance_snapshots
                WHERE currency = '$CUR' AND date(recorded_at, 'unixepoch') = date('now')
            )
            SELECT COALESCE(SUM(MAX(prev - topped_up_balance_cents, 0)), 0)
            FROM ordered WHERE prev IS NOT NULL;")
        rc=$(sqlite3 "$DB_FILE" \
            "SELECT COUNT(*) FROM balance_snapshots
             WHERE currency = '$CUR' AND date(recorded_at, 'unixepoch') = date('now');")
        printf "%-4s spent \$%s today  (%s snapshots)\n" \
            "$CUR" "$(cents_to_dollars "$sc")" "$rc"
    done
}

text_history() {
    local where=""
    [ "$CURRENCY" != "both" ] && where="WHERE currency = '$CURRENCY'"
    printf "%-4s %-8s %s\n" "CUR" "BALANCE" "RECORDED AT"
    while IFS='|' read -r c _ _ pc ts; do
        printf "%-4s \$%-8s %s\n" "$c" "$(cents_to_dollars "$pc")" "$ts"
    done < <(sqlite3 -separator '|' "$DB_FILE" \
        "SELECT currency,total_balance_cents,granted_balance_cents,topped_up_balance_cents,datetime(recorded_at, 'unixepoch') AS recorded_at
         FROM balance_snapshots $where ORDER BY id DESC LIMIT $N;")
}

text_summary() {
    for CUR in $(get_currencies); do
        local cc dt a7 a30
        cc=$(sqlite3 "$DB_FILE" \
            "SELECT topped_up_balance_cents FROM balance_snapshots
             WHERE currency = '$CUR' ORDER BY id DESC LIMIT 1;")
        dt=$(sqlite3 "$DB_FILE" \
            "SELECT COUNT(DISTINCT date(recorded_at, 'unixepoch'))
             FROM balance_snapshots WHERE currency = '$CUR';")
        a7=$(avg_daily_spend_cents "$CUR" 7)
        a30=$(avg_daily_spend_cents "$CUR" 30)
        printf "%-4s balance \$%s  avg \$%s/day (7d)  \$%s/day (30d)" \
            "$CUR" "$(cents_to_dollars "$cc")" "$(cents_to_dollars "$a7")" "$(cents_to_dollars "$a30")"
        if [ "$a30" != "0" ]; then
            local ed
            ed=$(awk -v b="$cc" -v a="$a30" 'BEGIN { printf "%d", b / a }')
            printf "  ~%s days left" "$ed"
        fi
        printf "  (%s days tracked)\n" "$dt"
    done
}


# --- Check alert --------------------------------------------------------------
_load_alert_thresholds() {
    # Only source secrets.env if env vars are not already set (env overrides file).
    if [ -z "${ALERT_THRESHOLD_USD_LOADED:-}" ]; then
        local secrets
        secrets="${XDG_CONFIG_HOME:-$HOME/.config}/deepseek-balance/secrets.env"
        if [ -f "$secrets" ]; then
            # Read threshold/command from file, but only if env didn't already provide them
            if [ -z "${ALERT_THRESHOLD_USD+set}" ]; then
                ALERT_THRESHOLD_USD=$(sed -n 's/^ALERT_THRESHOLD_USD=//p' "$secrets" 2>/dev/null || echo "")
            fi
            if [ -z "${ALERT_THRESHOLD_CNY+set}" ]; then
                ALERT_THRESHOLD_CNY=$(sed -n 's/^ALERT_THRESHOLD_CNY=//p' "$secrets" 2>/dev/null || echo "")
            fi
            if [ -z "${ALERT_COMMAND+set}" ]; then
                ALERT_COMMAND=$(sed -n 's/^ALERT_COMMAND=//p' "$secrets" 2>/dev/null || echo "")
            fi
        fi
        ALERT_THRESHOLD_USD_LOADED=1
    fi
}

json_check_alert() {
    _load_alert_thresholds
    local has_alert=0 first=1 pair cur thr bal bal_dollars thr_cents alert
    echo "{"
    for pair in "USD:${ALERT_THRESHOLD_USD:-}" "CNY:${ALERT_THRESHOLD_CNY:-}"; do
        cur="${pair%%:*}"
        thr="${pair#*:}"
        [ "$first" = 0 ] && echo ","
        first=0
        if [ -z "$thr" ]; then
            printf '  "%s": {"balance": null, "threshold": null, "alert": false}\n' "$cur"
        else
            bal=$(sqlite3 "$DB_FILE" \
                "SELECT topped_up_balance_cents FROM balance_snapshots
                 WHERE currency = '$cur' ORDER BY id DESC LIMIT 1;" 2>/dev/null || echo "")
            if [ -z "$bal" ]; then
                printf '  "%s": {"balance": null, "threshold": %s, "alert": false}\n' "$cur" "$thr"
            else
                bal_dollars=$(awk -v c="$bal" 'BEGIN { printf "%.2f", c / 100.0 }')
                thr_cents=$(awk -v t="$thr" 'BEGIN { printf "%d", (t + 0.0) * 100 + 0.5 }')
                alert="false"
                if [ "$bal" -lt "$thr_cents" ]; then
                    alert="true"
                    has_alert=1
                fi
                printf '  "%s": {"balance": %s, "threshold": %s, "alert": %s}\n' \
                    "$cur" "$bal_dollars" "$thr" "$alert"
            fi
        fi
    done
    echo "}"
    return $has_alert
}

text_check_alert() {
    _load_alert_thresholds
    local has_alert=0 pair cur thr bal bal_dollars thr_cents
    for pair in "USD:${ALERT_THRESHOLD_USD:-}" "CNY:${ALERT_THRESHOLD_CNY:-}"; do
        cur="${pair%%:*}"
        thr="${pair#*:}"
        if [ -z "$thr" ]; then
            printf "%-4s disabled  (no threshold configured)\n" "$cur"
            continue
        fi
        bal=$(sqlite3 "$DB_FILE" \
            "SELECT topped_up_balance_cents FROM balance_snapshots
             WHERE currency = '$cur' ORDER BY id DESC LIMIT 1;" 2>/dev/null || echo "")
        if [ -z "$bal" ]; then
            printf "%-4s no data   (threshold: \$%s)\n" "$cur" "$thr"
            continue
        fi
        bal_dollars=$(awk -v c="$bal" 'BEGIN { printf "%.2f", c / 100.0 }')
        thr_cents=$(awk -v t="$thr" 'BEGIN { printf "%d", (t + 0.0) * 100 + 0.5 }')
        if [ "$bal" -lt "$thr_cents" ]; then
            printf "%-4s \$%-8s ALERT     (threshold: \$%s)\n" "$cur" "$bal_dollars" "$thr"
            has_alert=1
        else
            printf "%-4s \$%-8s ok        (threshold: \$%s)\n" "$cur" "$bal_dollars" "$thr"
        fi
    done
    return $has_alert
}
# --- Dispatch --------------------------------------------------------------
case "$SUBCMD" in
    current)
        if [ "$OUTPUT_MODE" = "json" ]; then json_current; else text_current; fi ;;
    today)
        if [ "$OUTPUT_MODE" = "json" ]; then json_today; else text_today; fi ;;
    recent)
        if [ "$OUTPUT_MODE" = "json" ]; then json_recent; else text_recent; fi ;;
    history)
        if [ "$OUTPUT_MODE" = "json" ]; then json_history; else text_history; fi ;;
    summary)
        if [ "$OUTPUT_MODE" = "json" ]; then json_summary; else text_summary; fi ;;
    check-alert)
        if [ "$OUTPUT_MODE" = "json" ]; then json_check_alert; else text_check_alert; fi ;;
    *)  echo "deepseek-balance: unknown subcommand '$SUBCMD'" >&2; exit 2 ;;
esac
