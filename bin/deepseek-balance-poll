#!/usr/bin/env bash
set -euo pipefail

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    cat <<'EOF'
deepseek-balance-poll — fetch DeepSeek balance and record to local SQLite.

Usage:
  deepseek-balance-poll

Reads DEEPSEEK_API_KEY from:
  1. $DEEPSEEK_API_KEY environment variable
  2. ~/.config/deepseek-balance/secrets.env

Exit codes:
  0  Success — snapshot(s) recorded
  1  No API key found
  2  API call failed (non-200 response)
  3  API returned no matching currency rows

After recording, checks balance against ALERT_THRESHOLD_USD/CNY (if configured)
and runs ALERT_COMMAND when a threshold is breached (fires once, re-arms on recovery).

This is typically run by a systemd timer every 5 minutes.
EOF
    exit 0
fi

# --- Config ----------------------------------------------------------------
: "${CURRENCY:=both}"
: "${MAX_ROWS:=1000000}"
: "${RETENTION_DAYS:=0}"
DB_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/deepseek-balance-tracker"
DB_FILE="$DB_DIR/balance.db"
SECRETS_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/deepseek-balance/secrets.env"

# Validate currency
if [[ ! "$CURRENCY" =~ ^(USD|CNY|both)$ ]]; then
    echo "deepseek-balance-poll: invalid CURRENCY '$CURRENCY' — must be USD, CNY, or both" >&2
    exit 1
fi

# --- API key ---------------------------------------------------------------
if [ -z "${DEEPSEEK_API_KEY:-}" ]; then
    if [ -f "$SECRETS_FILE" ]; then
        key=$(sed -n 's/^DEEPSEEK_API_KEY=//p' "$SECRETS_FILE" 2>/dev/null || echo "")
        [ -n "$key" ] && DEEPSEEK_API_KEY="$key"
    fi
fi

if [ -z "${DEEPSEEK_API_KEY:-}" ]; then
    echo "deepseek-balance-poll: DEEPSEEK_API_KEY is not set. Set it in the environment or in $SECRETS_FILE" >&2
    exit 1
fi

# --- Ensure DB dir exists --------------------------------------------------
mkdir -p "$DB_DIR"
chmod 700 "$DB_DIR"

# sqlite3 wrapper with busy timeout (ms) — prevents instant failure if a
# reader is mid-query during a WAL checkpoint.
db() { sqlite3 "$DB_FILE" ".timeout 5000" "$@"; }

# --- Fetch balance from API ------------------------------------------------
RESPONSE=$(curl -s -w '\n%{http_code}' \
    -H "Authorization: Bearer $DEEPSEEK_API_KEY" \
    https://api.deepseek.com/user/balance)

HTTP_CODE=$(echo "$RESPONSE" | tail -1)
BODY=$(echo "$RESPONSE" | sed '$d')

if [ "$HTTP_CODE" != "200" ]; then
    echo "deepseek-balance-poll: API returned HTTP $HTTP_CODE: $BODY" >&2
    exit 2
fi

# --- Create table if not exists --------------------------------------------
sqlite3 "$DB_FILE" >/dev/null <<'SQL'
PRAGMA busy_timeout=5000;
PRAGMA journal_mode=WAL;
CREATE TABLE IF NOT EXISTS balance_snapshots (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    recorded_at INTEGER NOT NULL DEFAULT (unixepoch()),
    currency TEXT NOT NULL,
    total_balance_cents INTEGER NOT NULL,
    granted_balance_cents INTEGER NOT NULL,
    topped_up_balance_cents INTEGER NOT NULL
);
CREATE INDEX IF NOT EXISTS idx_snapshots_currency_time
    ON balance_snapshots(currency, recorded_at);
SQL
chmod 600 "$DB_FILE" 2>/dev/null || true

# --- Parse and insert ------------------------------------------------------
# Convert dollar strings to integer cents (e.g. "4.26" -> 426)
dollars_to_cents() {
    awk -v v="$1" 'BEGIN { printf "%d", (v + 0.0) * 100 + 0.5 }'
}

# Build a jq filter: if CURRENCY=both, keep all; else select only that currency
if [ "$CURRENCY" = "both" ]; then
    JQ_FILTER='.balance_infos[]'
else
    JQ_FILTER=".balance_infos[] | select(.currency == \"$CURRENCY\")"
fi

INSERTED=0
SQL_BATCH=""
while IFS='|' read -r currency total granted topped; do
    case "$currency" in
        USD|CNY) ;;
        *) echo "deepseek-balance-poll: unexpected currency '$currency' from API — skipping" >&2; continue ;;
    esac
    total_cents=$(dollars_to_cents "$total")
    granted_cents=$(dollars_to_cents "$granted")
    topped_cents=$(dollars_to_cents "$topped")
    SQL_BATCH="${SQL_BATCH}INSERT INTO balance_snapshots (currency, total_balance_cents, granted_balance_cents, topped_up_balance_cents) VALUES ('$currency', $total_cents, $granted_cents, $topped_cents);
"
    INSERTED=$((INSERTED + 1))
done < <(echo "$BODY" | jq -r "$JQ_FILTER | \"\(.currency)|\(.total_balance)|\(.granted_balance)|\(.topped_up_balance)\"")

if [ "$INSERTED" -gt 0 ]; then
    printf '.timeout 5000\n%s' "$SQL_BATCH" | sqlite3 "$DB_FILE"
fi

if [ "$INSERTED" -eq 0 ]; then
    echo "WARNING: No balance rows inserted (CURRENCY=$CURRENCY). API response: $BODY" >&2
    exit 3
fi

# --- Enforce row cap ---------------------------------------------------------
TOTAL=0
DELETED=0
if [ "$MAX_ROWS" -gt 0 ] 2>/dev/null; then
    IFS='|' read -r TOTAL CUTOFF <<< "$(sqlite3 -separator '|' "$DB_FILE" ".timeout 5000" "SELECT COUNT(*), COALESCE(MAX(id) - $MAX_ROWS, 0) FROM balance_snapshots;")"
    if [ "$TOTAL" -gt "$MAX_ROWS" ]; then
        DELETED=$(db \
            "DELETE FROM balance_snapshots WHERE id <= $CUTOFF; SELECT changes();")
    fi
fi

# --- Enforce retention (age-based pruning) ------------------------------------
RETENTION_DELETED=0
if [ "${RETENTION_DAYS:-0}" -gt 0 ] 2>/dev/null; then
    RETENTION_DELETED=$(db \
        "DELETE FROM balance_snapshots WHERE recorded_at < unixepoch('now', '-${RETENTION_DAYS} days'); SELECT changes();")
fi

if [ "$MAX_ROWS" -gt 0 ] 2>/dev/null; then
    echo "OK: inserted $INSERTED balance snapshot(s) (CURRENCY=$CURRENCY; rows=$TOTAL/$MAX_ROWS; deleted=$DELETED; retention_deleted=$RETENTION_DELETED)"
else
    TOTAL=$(db "SELECT COUNT(*) FROM balance_snapshots;")
    echo "OK: inserted $INSERTED balance snapshot(s) (CURRENCY=$CURRENCY; rows=$TOTAL (unlimited); retention_deleted=$RETENTION_DELETED)"
fi
# --- Alert check -------------------------------------------------------------
ALERT_STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/deepseek-balance-tracker"
ALERT_STATE_FILE="$ALERT_STATE_DIR/alert-state"
mkdir -p "$ALERT_STATE_DIR"
chmod 700 "$ALERT_STATE_DIR" 2>/dev/null || true

# Load threshold config from secrets if not already set (e.g. DEEPSEEK_API_KEY
# was provided via env and source was skipped above).
# Env vars take priority — only read from file if var is not already set.
if [ -f "$SECRETS_FILE" ]; then
    if [ -z "${ALERT_THRESHOLD_USD+set}" ]; then
        ALERT_THRESHOLD_USD=$(sed -n 's/^ALERT_THRESHOLD_USD=//p' "$SECRETS_FILE" 2>/dev/null || echo "")
    fi
    if [ -z "${ALERT_THRESHOLD_CNY+set}" ]; then
        ALERT_THRESHOLD_CNY=$(sed -n 's/^ALERT_THRESHOLD_CNY=//p' "$SECRETS_FILE" 2>/dev/null || echo "")
    fi
    if [ -z "${ALERT_COMMAND+set}" ]; then
        ALERT_COMMAND=$(sed -n 's/^ALERT_COMMAND=//p' "$SECRETS_FILE" 2>/dev/null || echo "")
    fi
fi

run_alert_check() {
    local currency="$1" threshold_var="$2"
    local threshold="${!threshold_var:-}"

    # Skip if threshold not set or empty
    [ -n "$threshold" ] || return 0

    # Lock around the full read-check-write cycle so two concurrent polls
    # can't both read "ok" and both fire the alert command.
    (
        flock -x 200

        # Get latest topped_up_balance in cents
        local balance_cents
        balance_cents=$(db \
            "SELECT topped_up_balance_cents FROM balance_snapshots
             WHERE currency = '$currency' ORDER BY id DESC LIMIT 1;")
        [ -n "$balance_cents" ] || exit 0  # No data yet

        # Read current alert state (default: ok)
        local current_state="ok"
        if [ -f "$ALERT_STATE_FILE" ]; then
            current_state=$(grep "^${currency}:" "$ALERT_STATE_FILE" 2>/dev/null | cut -d: -f2 || echo "ok")
        fi

        # Convert threshold to cents
        local threshold_cents
        threshold_cents=$(awk -v t="$threshold" 'BEGIN { printf "%d", (t + 0.0) * 100 + 0.5 }')
        local balance_dollars
        balance_dollars=$(awk -v c="$balance_cents" 'BEGIN { printf "%.2f", c / 100.0 }')

        # Update state file helper (already under lock)
        _write_alert_state() {
            local new_state="$1"
            if grep -q "^${currency}:" "$ALERT_STATE_FILE" 2>/dev/null; then
                sed -i "s/^${currency}:.*/${currency}:${new_state}/" "$ALERT_STATE_FILE"
            else
                echo "${currency}:${new_state}" >> "$ALERT_STATE_FILE"
            fi
        }

        if [ "$balance_cents" -lt "$threshold_cents" ] && [ "$current_state" = "ok" ]; then
            _write_alert_state "fired"
            echo "ALERT: ${currency} balance \$${balance_dollars} is below threshold \$${threshold} — executing ALERT_COMMAND" >&2
            if [ -n "${ALERT_COMMAND:-}" ]; then
                if [ -x "$ALERT_COMMAND" ]; then
                    DBT_BALANCE="$balance_dollars" \
                    DBT_BALANCE_CENTS="$balance_cents" \
                    DBT_THRESHOLD="$threshold" \
                    DBT_CURRENCY="$currency" \
                    "$ALERT_COMMAND" || true
                else
                    echo "ALERT: ALERT_COMMAND is not executable: $ALERT_COMMAND" >&2
                fi
            fi
        elif [ "$balance_cents" -ge "$threshold_cents" ] && [ "$current_state" = "fired" ]; then
            _write_alert_state "ok"
            echo "ALERT: ${currency} balance \$${balance_dollars} is back above threshold \$${threshold} — alert re-armed" >&2
        fi
    ) 200>"$ALERT_STATE_DIR/alert.lock"
}

run_alert_check "USD" "ALERT_THRESHOLD_USD"
run_alert_check "CNY" "ALERT_THRESHOLD_CNY"

