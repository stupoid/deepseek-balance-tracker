#!/usr/bin/env bash
set -euo pipefail

# --- Config ----------------------------------------------------------------
: "${CURRENCY:=both}"
DB_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/deepseek-balance-tracker"
DB_FILE="$DB_DIR/balance.db"
SECRETS_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/deepseek-balance/secrets.env"

# --- API key ---------------------------------------------------------------
if [ -z "${DEEPSEEK_API_KEY:-}" ]; then
    if [ -f "$SECRETS_FILE" ]; then
        # shellcheck source=/dev/null
        source "$SECRETS_FILE"
    fi
fi

if [ -z "${DEEPSEEK_API_KEY:-}" ]; then
    echo "ERROR: DEEPSEEK_API_KEY is not set. Set it in the environment or in $SECRETS_FILE" >&2
    exit 1
fi

# --- Ensure DB dir exists --------------------------------------------------
mkdir -p "$DB_DIR"

# --- Fetch balance from API ------------------------------------------------
RESPONSE=$(curl -s -w '\n%{http_code}' \
    -H "Authorization: Bearer $DEEPSEEK_API_KEY" \
    https://api.deepseek.com/user/balance)

HTTP_CODE=$(echo "$RESPONSE" | tail -1)
BODY=$(echo "$RESPONSE" | sed '$d')

if [ "$HTTP_CODE" != "200" ]; then
    echo "ERROR: API returned HTTP $HTTP_CODE: $BODY" >&2
    exit 2
fi

# --- Create table if not exists --------------------------------------------
sqlite3 "$DB_FILE" <<'SQL'
CREATE TABLE IF NOT EXISTS balance_snapshots (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    recorded_at TEXT NOT NULL DEFAULT (datetime('now')),
    currency TEXT NOT NULL,
    total_balance_cents INTEGER NOT NULL,
    granted_balance_cents INTEGER NOT NULL,
    topped_up_balance_cents INTEGER NOT NULL
);
CREATE INDEX IF NOT EXISTS idx_snapshots_currency_time
    ON balance_snapshots(currency, recorded_at);
SQL

# --- Parse and insert ------------------------------------------------------
# Convert dollar strings to integer cents (e.g. "4.26" -> 426)
dollars_to_cents() {
    awk -v v="$1" 'BEGIN { printf "%d", (v + 0.0) * 100 + 0.5 }'
}

# Build a jq filter: if CURRENCY=both, keep all; else select only that currency
if [ "$CURRENCY" = "both" ]; then
    JQ_FILTER='.balance_infos[]'
else
    JQ_FILTER=".balance_infos[] | select(.currency == \"$CURRENCY\")"
fi

INSERTED=0
while IFS='|' read -r currency total granted topped; do
    total_cents=$(dollars_to_cents "$total")
    granted_cents=$(dollars_to_cents "$granted")
    topped_cents=$(dollars_to_cents "$topped")
    sqlite3 "$DB_FILE" \
        "INSERT INTO balance_snapshots (currency, total_balance_cents, granted_balance_cents, topped_up_balance_cents)
         VALUES ('$currency', $total_cents, $granted_cents, $topped_cents);"
    INSERTED=$((INSERTED + 1))
done < <(echo "$BODY" | jq -r "$JQ_FILTER | \"\(.currency)|\(.total_balance)|\(.granted_balance)|\(.topped_up_balance)\"")

if [ "$INSERTED" -eq 0 ]; then
    echo "WARNING: No balance rows inserted (CURRENCY=$CURRENCY). API response: $BODY" >&2
    exit 3
fi

echo "OK: inserted $INSERTED balance snapshot(s) (CURRENCY=$CURRENCY)"
