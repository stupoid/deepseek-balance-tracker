# DeepSeek Balance Tracker — secrets file
#
# Copy to ~/.config/deepseek-balance/secrets.env and restrict permissions:
#   mkdir -p ~/.config/deepseek-balance
#   chmod 700 ~/.config/deepseek-balance
#   cp secrets.env.example ~/.config/deepseek-balance/secrets.env
#   chmod 600 ~/.config/deepseek-balance/secrets.env
#
# Get your API key at: https://platform.deepseek.com/api_keys

DEEPSEEK_API_KEY=sk-your-api-key-here

# Currency filter: USD, CNY, or both (default)
CURRENCY=both

# Auto-delete snapshots older than N days (default: 0 = keep forever)
RETENTION_DAYS=90

# Alert when topped-up balance drops below this threshold (in dollars/yuan).
# Omit or leave empty to disable alerts for that currency.
# ALERT_THRESHOLD_USD=1.00
# ALERT_THRESHOLD_CNY=10.00

# Shell script to execute when an alert fires.
# Receives DBT_BALANCE, DBT_BALANCE_CENTS, DBT_THRESHOLD, DBT_CURRENCY env vars.
# ALERT_COMMAND=/home/kelvin/code/deepseek-balance-tracker/etc/alert-low-balance.sh

# Telegram credentials for the bundled alert script (etc/alert-low-balance.sh).
# ALERT_TELEGRAM_BOT_TOKEN=123456:ABC...
# ALERT_TELEGRAM_CHAT_ID=123456789
